{
  "name": "complianceguard-desktop",
  "version": "1.0.0",
  "description": "ComplianceGuard - SOC 2 Automation Desktop Application",
  "main": "electron/main.js",
  "author": "Egyan07",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"cd frontend && npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "cd frontend && npm run build",
    "package": "npm run build && electron-builder --win --x64",
    "package:all": "npm run build && electron-builder --win --x64 --linux --mac",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "sqlite3": "^5.1.6",
    "electron-store": "^8.1.0",
    "electron-log": "^4.4.8"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.complianceguard.desktop",
    "productName": "ComplianceGuard",
    "copyright": "Copyright © 2024 Egyan07",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        "msi",
        "nsis"
      ],
      "icon": "resources/icons/icon.ico",
      "legalTrademark": "ComplianceGuard",
      "publisherName": "ComplianceGuard LLC",
      "verifyUpdateCodeSignature": false,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "msi": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ComplianceGuard"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ComplianceGuard",
      "menuCategory": true,
      "perMachine": true
    }
  }
}