# ComplianceGuard SOC 2 Automation Platform - Environment Variables
# Copy this file to .env and customize for your environment

# ===========================================================================
# Database Configuration
# ===========================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://complianceguard:complianceguard@localhost:5432/complianceguard

# Database credentials (used by docker-compose)
DB_USER=complianceguard
DB_PASSWORD=complianceguard
DB_HOST=db
DB_PORT=5432
DB_NAME=complianceguard


# ===========================================================================
# Security Configuration
# ===========================================================================

# Secret key for JWT token signing
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Password hashing
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_UPPERCASE=true


# ===========================================================================
# AWS Integration (for evidence collection)
# ===========================================================================

# AWS credentials for evidence collection
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# AWS services configuration
AWS_CLOUDTRAIL_ENABLED=true
AWS_CONFIG_ENABLED=true
AWS_CLOUDWATCH_ENABLED=true

# S3 bucket for evidence storage (optional)
AWS_EVIDENCE_BUCKET=complianceguard-evidence


# ===========================================================================
# Application Configuration
# ===========================================================================

# Environment mode
ENVIRONMENT=development  # development, staging, production

# Debug settings
DEBUG=true
LOG_LEVEL=info  # debug, info, warning, error

# API Configuration
API_VERSION=v1
API_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://yourdomain.com"]
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100


# ===========================================================================
# Frontend Configuration
# ===========================================================================

# API base URL for frontend
VITE_API_BASE_URL=http://localhost:8000

# Application branding
VITE_APP_TITLE=ComplianceGuard SOC 2 Platform
VITE_APP_VERSION=0.1.0
VITE_APP_DESCRIPTION=SOC 2 compliance automation platform

# Feature flags
VITE_ENABLE_AWS_INTEGRATION=true
VITE_ENABLE_MULTI_COMPANY=true
VITE_ENABLE_ADVANCED_REPORTING=false

# UI Configuration
VITE_DEFAULT_THEME=light  # light, dark
VITE_DEFAULT_LANGUAGE=en

# Sentry error monitoring (optional - no-op when unset)
VITE_SENTRY_DSN=


# ===========================================================================
# Email Configuration
# ===========================================================================

# Set EMAIL_ENABLED=true and configure SMTP_* to send real emails.
# When EMAIL_ENABLED=false (default), verification/reset tokens are logged but not sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@complianceguard.com
SMTP_FROM_NAME=ComplianceGuard
SMTP_TLS=true
SMTP_SSL=false
EMAIL_ENABLED=false
APP_BASE_URL=https://yourdomain.com


# ===========================================================================
# Monitoring and Analytics
# ===========================================================================

# Health check configuration
HEALTH_CHECK_INTERVAL=60
HEALTH_CHECK_TIMEOUT=10

# Metrics collection
ENABLE_METRICS=false
METRICS_PORT=9090

# External monitoring (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Analytics (optional)
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=


# ===========================================================================
# File Storage
# ===========================================================================

# Local file storage
LOCAL_STORAGE_PATH=/app/storage
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,json,csv,xlsx

# Evidence retention
EVIDENCE_RETENTION_DAYS=2555  # 7 years for compliance
AUTO_DELETE_EXPIRED=false


# ===========================================================================
# Compliance Framework Configuration
# ===========================================================================

# Default SOC 2 framework
SOC2_DEFAULT_FRAMEWORK=soc2-type2
SOC2_AUTOMATIC_EVIDENCE_COLLECTION=true
SOC2_EVIDENCE_COLLECTION_INTERVAL=86400  # 24 hours

# Control testing
CONTROL_TESTING_ENABLED=true
CONTROL_TESTING_INTERVAL=604800  # 7 days

# Risk assessment
RISK_ASSESSMENT_ENABLED=true
RISK_ASSESSMENT_FREQUENCY=2592000  # 30 days


# ===========================================================================
# Backup and Recovery
# ===========================================================================

# Database backup
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Disaster recovery
DR_PLAN_ENABLED=false
DR_NOTIFICATION_EMAILS=admin@yourcompany.com


# ===========================================================================
# Testing Configuration (for development)
# ===========================================================================

# Test database
TEST_DATABASE_URL=sqlite:///test_complianceguard.db

# Mock AWS for testing
MOCK_AWS_SERVICES=true
MOCK_EMAIL_SERVICE=true

# Test users
TEST_ADMIN_EMAIL=admin@test.com
TEST_ADMIN_PASSWORD=test123
TEST_USER_EMAIL=user@test.com
TEST_USER_PASSWORD=test123


# ===========================================================================
# Docker Configuration
# ===========================================================================

# Container resource limits
BACKEND_MEMORY_LIMIT=512M
BACKEND_CPU_LIMIT=0.5
FRONTEND_MEMORY_LIMIT=256M
FRONTEND_CPU_LIMIT=0.3
DB_MEMORY_LIMIT=1G
DB_CPU_LIMIT=0.5

# Network configuration
NETWORK_DRIVER=bridge


# ===========================================================================
# Advanced Configuration
# ===========================================================================

# Database connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Session configuration
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# Cache configuration
CACHE_TYPE=redis  # memory, redis
CACHE_REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TIMEOUT=300

# Queue configuration
QUEUE_TYPE=redis  # memory, redis, rabbitmq
QUEUE_REDIS_URL=redis://redis:6379/1
QUEUE_DEFAULT_TIMEOUT=3600

# ===========================================================================
# Production Security Recommendations
# ===========================================================================

# Uncomment and set in production:

# # Stronger secret key
# SECRET_KEY=$(openssl rand -hex 32)

# # Disable debug in production
# DEBUG=false
# ENVIRONMENT=production

# # Secure CORS
# CORS_ORIGINS=["https://yourdomain.com"]

# # Enable rate limiting
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_BURST=150

# # Enable monitoring
# SENTRY_DSN=your-sentry-dsn
# ENABLE_METRICS=true

# # Secure email
# SMTP_HOST=your-smtp-server
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# # Enable backups
# BACKUP_ENABLED=true
# DR_PLAN_ENABLED=true

# # Secure session cookies
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_HTTPONLY=true

# # Enable advanced security features
# PASSWORD_MIN_LENGTH=12
# PASSWORD_REQUIRE_SPECIAL=true
# PASSWORD_REQUIRE_NUMBERS=true
# PASSWORD_REQUIRE_UPPERCASE=true

# ===========================================================================
# Usage Instructions
# ===========================================================================

# 1. Copy this file to .env in the project root:
#    cp .env.example .env

# 2. Edit the .env file with your specific configuration

# 3. Never commit .env to version control

# 4. For production, ensure all security-sensitive values are properly set

# 5. Use environment-specific .env files:
#    - .env.development for development
#    - .env.staging for staging
#    - .env.production for production

# 6. Restart containers after changing environment variables:
#    docker-compose down && docker-compose up -d

# ===========================================================================
# Troubleshooting
# ===========================================================================

# If database connection fails:
# - Verify DATABASE_URL format
# - Check DB_HOST and DB_PORT
# - Ensure database service is running

# If AWS integration fails:
# - Verify AWS credentials
# - Check AWS region
# - Ensure IAM permissions are correct

# If frontend cannot connect to backend:
# - Check VITE_API_BASE_URL
# - Verify backend service is running
# - Check CORS configuration

# For more help, see README.md
